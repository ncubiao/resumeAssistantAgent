# ================ 应用配置 ================
APP_ENV=dev
APP_NAME=resumeAssistantAgent
DEBUG=true

# ================ 后端服务 ================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ================ 数据库 ================
DATABASE_URL=sqlite:///./resume_agent.db
# 若使用 Docker Compose:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/resume_agent

# ================ LLM 配置（3 种提供商选一个启用 ================
# 1) 阿里云 DashScope (Qwen / 通义千问 —— OpenAI 兼容模式（推荐国内用户）
LLM_PROVIDER=dashscope
LLM_API_KEY=你的openai_key
LLM_MODEL=qwen3-vl-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# 2) OpenAI 官方
# LLM_PROVIDER=openai
# LLM_API_KEY=你的openai_key
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# 3) DeepSeek
# LLM_PROVIDER=deepseek
# LLM_API_KEY=你的deepseek_key
# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com/v1

# ================ 向量检索 ================
VECTOR_INDEX_PATH=./data/vector_index/faiss_index.bin
VECTOR_DIM=1536

# ================ Embedding（向量化，可独立于 LLM 切换）================
# 留空则自动回退：provider 跟随 LLM、key 复用 LLM_API_KEY、维度按 provider 推断
# EMBEDDING_PROVIDER=dashscope
# EMBEDDING_MODEL=text-embedding-v3
# EMBEDDING_DIM=1024
# EMBEDDING_BASE_URL=
# EMBEDDING_API_KEY=

# ================ 文件上传 ================
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=20

# ================ 日志 ================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ================ 生产加固（阶段 5，默认关闭以便本地/demo 直接可用）================
# 鉴权：开启后所有 /api/v1/* 业务接口需带 X-API-Key 头
AUTH_ENABLED=false
API_KEYS=                       # 逗号分隔的合法 key，如 key-aaa,key-bbb
# CORS：逗号分隔的允许来源（不要在生产用 *）
CORS_ALLOW_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
# 限流：按客户端 IP 的 60s 滑动窗口
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=120

# 前端（Streamlit）连接后端时，若后端开启了鉴权，需提供同一个 key：
# BACKEND_API_KEY=key-aaa
