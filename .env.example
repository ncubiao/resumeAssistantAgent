# Application Settings
APP_ENV=dev
APP_NAME=resumeAssistantAgent
DEBUG=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend API Endpoint (used by Streamlit)
BACKEND_API_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/resume_agent
# For sqlite fallback:
# DATABASE_URL=sqlite:///./resume_agent.db

# LLM Configuration
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# Alternative: DeepSeek
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-your-deepseek-key
# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com

# Vector Store
VECTOR_INDEX_PATH=./data/vector_index/faiss_index.bin
VECTOR_DIM=1536

# File Storage
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=20

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
