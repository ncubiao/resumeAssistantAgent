# ================ 应用配置 ================
APP_ENV=dev
APP_NAME=resumeAssistantAgent
DEBUG=true

# ================ 后端服务 ================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ================ 数据库 ================
DATABASE_URL=sqlite:///./resume_agent.db
# 若使用 Docker Compose:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/resume_agent

# ================ LLM 配置（3 种提供商选一个启用 ================
# 1) 阿里云 DashScope (Qwen / 通义千问 —— OpenAI 兼容模式（推荐国内用户）
LLM_PROVIDER=dashscope
LLM_API_KEY=sk-
LLM_MODEL=qwen3-vl-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# 2) OpenAI 官方
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-你的openai_key
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# 3) DeepSeek
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-你的deepseek_key
# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com/v1

# ================ 向量检索 ================
VECTOR_INDEX_PATH=./data/vector_index/faiss_index.bin
VECTOR_DIM=1536

# ================ 文件上传 ================
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=20

# ================ 日志 ================
LOG_LEVEL=INFO
LOG_FORMAT=json
